# Selene Backend Configuration

# Flask secret key for JWT signing (REQUIRED - generate a strong random value)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Target Database URL
# For PostgreSQL: postgresql://username:password@localhost:5432/selene
# If left empty, the application will fallback to a local SQLite database (sqlite:///selene.db)
DATABASE_URL=

# CORS Settings (origins separated by commas)
ALLOWED_ORIGINS=http://localhost:5173

# Debug mode (true for development, false for production)
FLASK_DEBUG=false

# Cookie Security (set to 'false' only for local development without HTTPS)
SESSION_COOKIE_SECURE=true
